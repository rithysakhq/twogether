{
  "expo": {
    "name": "Twogether 2.0",
    "slug": "twogether-2-0",
    "scheme": "twogether2",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/twogether-2-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F13"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.twogether2",
      "icon": "./assets/twogether-2-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/twogether-2-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.twogether2"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow Twogether 2.0 to access your microphone to record voice messages for your partner."
        }
      ],
      "expo-router"
    ]
  }
}
