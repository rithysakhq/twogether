{
  "expo": {
    "name": "twogether-app",
    "slug": "twogether-app",
    "scheme": "twogether",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/twogether_icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F13"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.twogether-app",
      "icon": "./assets/twogether_icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/twogether_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.twogetherapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow Twogether to access your microphone to record voice messages for your partner."
        }
      ],
      "expo-router"
    ]
  }
}
